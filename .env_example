# GreenBoost — Hardware overrides
# Copy this file to .env and uncomment/edit the values you want to override.
# All parameters are auto-detected by default. Only set values here if the
# auto-detection is wrong or you want to tune manually.
#
# Usage:
#   cp .env_example .env
#   nano .env
#   sudo ./greenboost_setup.sh full-install

# ── GPU ──────────────────────────────────────────────────────────────────
# Physical VRAM in GB (auto-detected via nvidia-smi)
# ENV_GB_PHYS=16

# ── DDR pool (Tier 2) ───────────────────────────────────────────────────
# Virtual VRAM pool size in GB (default: 80% of RAM - reserve)
# ENV_GB_VIRT=40

# System RAM in GB to keep free (default: 15% of RAM, min 8, max 16)
# ENV_GB_RESERVE=12

# ── NVMe swap (Tier 3) ──────────────────────────────────────────────────
# NVMe swap capacity in GB (default: 4 * VRAM, clamped 32-200)
# ENV_GB_NVME_SWAP=64

# GreenBoost T3 soft cap in GB (default: 90% of swap)
# ENV_GB_NVME_POOL=58

# ── CPU topology ─────────────────────────────────────────────────────────
# Highest P-core CPU number (auto-detected via sysfs core_type)
# On non-hybrid CPUs (AMD, older Intel), set to (nproc - 1)
# ENV_GB_PCORES_MAX=15

# Golden core range — highest-frequency cores for inference pinning
# ENV_GB_GOLDEN_MIN=4
# ENV_GB_GOLDEN_MAX=7

# Pin watchdog to P-cores only (1=yes, 0=no; auto: 1 for hybrid, 0 otherwise)
# ENV_GB_PCORES_ONLY=1

# ── Ollama ───────────────────────────────────────────────────────────────
# Context window size in tokens (auto-sized based on total pool)
#   pool >= 40 GB → 131072 | >= 24 GB → 65536 | >= 16 GB → 32768
# ENV_GB_OLLAMA_CTX=131072
